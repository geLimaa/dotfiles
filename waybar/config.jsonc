{
    "layer": "top",
    "position": "left",

    "modules-left": ["clock", "group/misc"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["memory", "group/volume", "network", "battery"],

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "orientation": "vertical"
    },

    "group/volume": {
        "orientation": "vertical",
        "drawer": {
            "transition-duration": 500,
            "transition-top-to-bottom": true
        },
        "modules": ["pulseaudio", "pulseaudio/slider"]
    },

    "group/misc": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "misc-modules",
            "transition-top-to-bottom": false
        },
        "modules": [
            "custom/separator",
            "custom/notification",
            "power-profiles-daemon"
        ]
    },

    "custom/separator": {
        "format": "â€”",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "cursor": "pointer"
    },

    "custom/weather": {
        "exec": "${HOME}/.config/waybar/scripts/get-weather.sh Bangalore+India",
        "return-type": "json",
        "format": "{}",
        "tooltip": true,
        "interval": 3600
    },

    "custom/notification": {
        "tooltip": true,
        "tooltip-format": "Left Click: Launch Notification Center\nRight Click: Do not Disturb",
        "format": "{icon}",
        "format-icons": {
            "notification": "َ°‚ڑ<span foreground='red'><sup>ï‘„</sup></span>",
            "none": "َ°‚ڑ",
            "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-none": "ï‡·",
            "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
            "inhibited-none": "ï‚¢",
            "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-inhibited-none": "ï‡·"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/launcher": {
        "format": "ïŒ“",
        "on-click": "bash /home/$USER/.config/waybar/scripts/app_launcher.sh",
        "tooltip-format": "Launch your favorite apps"
    },

    "custom/media": {
        "format": "{}",
        "escape": true,
        "return-type": "json",
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "smooth-scrolling-threshold": 1, // This value was tested using a trackpad, it should be lowered if using a mouse.
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null" // Script in resources/custom_modules folder
    },

    "custom/pacman": {
        "format": "َ°®¯ {}",
        "interval": "once",
        "exec": "checkupdates | wc -l",
        "on-click": "update-system",
        "signal": 8,
        "tooltip-format": "{} updates available"
    },

    "battery": {
        "format": "{icon}",
        "format-charging": "َ°‚„",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip-format": "Battery is at {capacity}%"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "ïٹ”",
        "format-muted": "î»¨",
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "ignored-sinks": ["Easy Effects Sink"],
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï–گ",
            "headset": "ï–گ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["ï€¦", "ï€§", "ï€¨"]
        },
        "tooltip-format": "Volume: {volume}%"
    },

    "network": {
        "interface": "wlan0",
        "format": "{ifname}",
        "format-wifi": "{icon}",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°–ھ",
        "max-length": 50,
        "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
        "tooltip-format": "Connected to {essid}"
    },

    "memory": {
        "interval": 5,
        "format": "َ°چ›",
        "tooltip": true,
        "tooltip-format": "RAM: {percentage}%\n{used:0.1f}G / {total:0.1f}G"
    },

    "clock": {
        "format": "{:%H\n%M}",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<span color='#fAfBfC'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "shift_down",
            "on-click": "shift_up"
        }
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power mode: {profile}",
        "tooltip": true,
        "format-icons": {
            "default": "ïƒ§",
            "performance": "ïƒ§",
            "balanced": "ï‰ژ",
            "power-saver": "ïپ¬"
        }
    }
}            
